# Root env file read by docker-compose for variable substitution.
# Copy to `.env` (same folder as docker-compose.yml) and fill in your key.

# Gemini (Google) API — powers AI GUARD Mapping.
# Get a key at https://aistudio.google.com/apikey.
# If left empty, the app falls back to a deterministic local mapping engine.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash-lite
