# Local PostgreSQL connection (matches docker-compose service `db`).
# When running the backend outside Docker against the compose Postgres, use localhost.
DATABASE_URL=postgresql://attacked:attacked@localhost:5433/attacked

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Gemini (Google) API for AI GUARD Mapping. Empty → local fallback engine.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash-lite
